{
  "name": "qbadger",
  "version": "0.1.0",
  "description": "Async AI automation system built on Claude Code SDK",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src/ test/",
